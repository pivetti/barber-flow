// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BarberRole {
  OWNER
  ADMIN
  BARBER
}

enum BookingStatus {
  SCHEDULED
  DONE
  CANCELED
}

model Service {
  id                  String    @id @default(uuid())
  name                String
  description         String
  imageUrl            String
  price               Decimal   @db.Decimal(10, 2)
  durationMinutes     Int       @default(30)
  bufferBeforeMinutes Int       @default(0)
  bufferAfterMinutes  Int       @default(0)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  bookings            Booking[]
}

model Barber {
  id              String               @id @default(uuid())
  name            String
  email           String?              @unique
  phone           String?
  password        String?
  sessionVersion  Int                  @default(0)
  imageUrl        String
  role            BarberRole           @default(BARBER)
  isActive        Boolean              @default(true)
  bookings        Booking[]
  availabilities  BarberAvailability[]
  blockedDays     BarberBlockedDay[]
  blockedSlots    BarberBlockedSlot[]
  workingHours    WorkingHour[]
  blockedTimes    BlockedTime[]
  scheduleSetting ScheduleSettings?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model Booking {
  id                         String        @id @default(uuid())
  customerName               String
  customerPhone              String
  cancellationToken          String        @unique
  cancellationRequested      Boolean       @default(false)
  cancellationRequestedAt    DateTime?
  status                     BookingStatus @default(SCHEDULED)
  serviceId                  String
  serviceName                String
  servicePrice               Decimal       @db.Decimal(10, 2)
  serviceDurationMinutes     Int
  serviceBufferBeforeMinutes Int           @default(0)
  serviceBufferAfterMinutes  Int           @default(0)
  barberId                   String
  barber                     Barber        @relation(fields: [barberId], references: [id], onDelete: Restrict)
  startsAt                   DateTime
  endsAt                     DateTime
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  service                    Service       @relation(fields: [serviceId], references: [id])

  @@index([barberId, startsAt])
  @@index([barberId, endsAt])
  @@index([barberId, status])
}

model BarberAvailability {
  id        String   @id @default(uuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barberId, dayOfWeek, time])
  @@index([barberId, dayOfWeek])
}

model BarberBlockedDay {
  id        String   @id @default(uuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barberId, date])
  @@index([barberId, date])
}

model BarberBlockedSlot {
  id        String   @id @default(uuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barberId, date])
  @@index([barberId, date])
}

model WorkingHour {
  id        String   @id @default(uuid())
  barberId  String   @map("barber_id")
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([barberId, dayOfWeek, startTime, endTime])
  @@index([barberId, dayOfWeek])
  @@map("working_hours")
}

model BlockedTime {
  id        String   @id @default(uuid())
  barberId  String   @map("barber_id")
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  date      DateTime
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([barberId, date])
  @@map("blocked_times")
}

model ScheduleSettings {
  id                  String   @id @default(uuid())
  barberId            String   @unique @map("barber_id")
  barber              Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  slotIntervalMinutes Int      @default(30) @map("slot_interval_minutes")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("schedule_settings")
}

model AdminLoginAttempt {
  id              String    @id @default(uuid())
  email           String
  ipAddress       String
  failedAttempts  Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  lastAttemptAt   DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([email, ipAddress])
  @@index([blockedUntil])
}

model RateLimitAttempt {
  id              String    @id @default(uuid())
  ipAddress       String
  route           String
  attemptCount    Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([ipAddress, route])
  @@index([blockedUntil])
}

model SiteSettings {
  id                      String   @id @default("default")
  businessName            String   @default("Barbearia do Jesi")
  businessLocation        String   @default("")
  businessDescription     String   @default("Agendamentos online para uma experiencia simples, organizada e premium.")
  logoUrl                 String   @default("/logo-jesi.png")
  bannerUrl               String   @default("/banner-jesi.png")
  primaryColor            String   @default("#C7A15A")
  secondaryColor          String   @default("#D8B56C")
  accentColor             String   @default("#E7C979")
  backgroundGradientColor String   @default("#C7A15A")
  businessEmail           String   @default("contato@barbeariadojesi.com.br")
  businessPhone           String   @default("(00) 00000-0000")
  whatsappPhone           String   @default("")
  privacyEmail            String   @default("privacidade@barbeariadojesi.com.br")
  privacyPhone            String   @default("(00) 00000-0000")
  privacyResponsible      String   @default("Barbearia do Jesi")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
